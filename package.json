{
  "name": "refi-radar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @refi-radar/web --filter @refi-radar/worker dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "ios:add": "cap add ios",
    "ios:sync": "pnpm --filter @refi-radar/web build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/push-notifications": "^8.0.4",
    "@capacitor/status-bar": "^8.0.2"
  }
}
